// SkillSync — Prisma Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured via prisma.config.ts (Prisma v7)
  // and passed to PrismaClient via the @prisma/adapter-pg driver adapter.
}

// ─── NextAuth Required Models ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Application Models ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  activityLogs  ActivityLog[]
  insights      Insight[]
  weeklyReports WeeklyReport[]
  domains       UserDomain[]
  goals         Goal[]
}

// A "domain" is a life area the user wants to track (e.g., Coding, Fitness)
model Domain {
  id          String       @id @default(cuid())
  name        String       @unique // e.g. "Coding", "Fitness", "Reading", "Mood", "SideProject"
  icon        String       // emoji or icon name
  color       String       // hex color for UI
  description String?
  isCustom    Boolean      @default(false) // true for user-created domains
  createdBy   String?      // userId of creator for custom domains

  userDomains  UserDomain[]
  activityLogs ActivityLog[]
  goals        Goal[]
}

// Allows users to personalise which domains they track
model UserDomain {
  id       String  @id @default(cuid())
  userId   String
  domainId String
  isActive Boolean @default(true)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@unique([userId, domainId])
}

// A single activity log entry for a user in a specific domain
model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  domainId   String
  loggedAt   DateTime @default(now())  // when the activity actually took place
  createdAt  DateTime @default(now())
  
  // Quantitative fields
  value      Float?   // generic numeric value (e.g. 45 for "45 min workout", 3 for "3 problems solved")
  unit       String?  // e.g. "minutes", "problems", "pages", "km"
  
  // Qualitative fields
  mood       Int?     // 1–10 mood score (used for mood domain)
  energy     Int?     // 1–10 energy level
  notes      String?  @db.Text
  
  // Structured metadata (JSON) for domain-specific data
  metadata   Json?    // e.g. { "exercises": [...], "commits": 5, "bookTitle": "..." }

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@index([userId, domainId])
}

// AI-generated insight: a single discovered correlation or pattern
model Insight {
  id              String   @id @default(cuid())
  userId          String
  weeklyReportId  String?
  
  insightText     String   @db.Text  // human-readable explanation
  domainsInvolved String[] // domain names involved in the correlation
  confidenceLevel Float    // 0.0 – 1.0
  recommendation  String   @db.Text  // actionable recommendation
  insightType     InsightType @default(CORRELATION)
  
  createdAt       DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyReport WeeklyReport? @relation(fields: [weeklyReportId], references: [id])

  @@index([userId, createdAt])
}

enum InsightType {
  CORRELATION
  TIMING_OPTIMIZATION
  TREND
  WARNING
  WIN
}

// A weeky aggregated report generated by the AI
model WeeklyReport {
  id           String   @id @default(cuid())
  userId       String
  weekStart    DateTime // Monday of the report week
  weekEnd      DateTime // Sunday of the report week
  
  summary      String   @db.Text   // AI-generated plain-language summary
  totalLogs    Int      @default(0)
  domainsActive String[]           // which domains had activity this week
  
  generatedAt  DateTime @default(now())
  isRead       Boolean  @default(false)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  insights Insight[]

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
}

// Weekly or monthly goal for a domain
model Goal {
  id          String   @id @default(cuid())
  userId      String
  domainId    String
  targetValue Float    // e.g. 10 (hours per week)
  unit        String   // e.g. "hours", "problems", "km"
  period      String   @default("weekly") // "weekly" | "monthly"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@unique([userId, domainId, period])
  @@index([userId])
}
